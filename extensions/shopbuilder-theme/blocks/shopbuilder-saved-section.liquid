<div
  id="shopbuilder-app-block-{{ block.id }}"
  class="shopbuilder-app-block"
  data-shopbuilder-block
  data-instance="{{ block.id }}"
  data-handle="{{ block.settings.section_handle | escape }}"
  data-proxy-url="/apps/shopbuilder/section"
  {{ block.shopify_attributes }}
>
  <div class="shopbuilder-app-block__placeholder">
    Loading ShopBuilder section...
  </div>
</div>

{% schema %}
{
  "name": "ShopBuilder section",
  "target": "section",
  "stylesheet": "shopbuilder-saved-section.css",
  "javascript": "shopbuilder-saved-section.js",
  "enabled_on": {
    "templates": ["index", "page", "product", "collection", "blog", "article", "search", "cart", "list-collections", "404"]
  },
  "settings": []
}
{% endschema %}
